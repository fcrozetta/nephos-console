node_modules/
/build
/.svelte-kit
/package
.env
.env.*
!.env.example
vite.config.*.timestamp-*
/src/lib/api/generated.d.ts
.DS_Store

# rctx: .rctx/ is committed source of truth. Keep the whole tree
# tracked so a claim scope folder matching an ignore rule (build/, bin/,
# out/, ...) can't be silently dropped. Must come after those rules.
!.rctx/
!.rctx/**/
!.rctx/**
# The FTS index is a cache under ~/.cache/rctx. Re-ignore its old in-repo
# location (last match wins) so a leftover DB can't be committed.
.rctx/cache/
